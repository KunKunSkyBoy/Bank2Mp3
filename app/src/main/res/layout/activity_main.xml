<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════ 标题 ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🎵 Bank → 多格式"
                android:textSize="22sp"
                android:textColor="@color/dark_gold"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnThemeToggle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="☀️"
                android:textSize="18sp"
                android:background="@color/dark_surface"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FMOD .bank 音频提取 · 依赖 Operit 终端桥接"
            android:textSize="12sp"
            android:textColor="@color/dark_text2"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 桥接状态栏 ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/dark_surface"
            android:padding="10dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/bridgeStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔴 未连接"
                android:textSize="13sp"
                android:textColor="#E74C3C" />

            <TextView
                android:id="@+id/btnBridgeRefresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@color/dark_accent"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp"
                android:minWidth="36dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btnBridgeStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚀 启动"
                android:textSize="14sp"
                android:textColor="#1A1A2E"
                android:background="@color/dark_gold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <!-- ═══════════ 文件选择 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📄 输入"
            android:textSize="13sp"
            android:textColor="@color/dark_text"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btnPickFile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="选择 .bank"
                android:textSize="14sp"
                android:minHeight="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="@color/dark_accent" />

            <Button
                android:id="@+id/btnPickFolder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="选择目录"
                android:textSize="14sp"
                android:minHeight="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:backgroundTint="@color/dark_surface2" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未选择文件"
            android:textSize="12sp"
            android:textColor="@color/dark_text2"
            android:ellipsize="middle"
            android:maxLines="2"
            android:layout_marginBottom="12dp" />

        <!-- ═══════════ 输出目录 ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnPickOutput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📂 输出目录"
                android:textSize="12sp"
                android:minHeight="0dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="@color/dark_surface2" />

            <Button
                android:id="@+id/btnResetOutput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="恢复默认"
                android:textSize="12sp"
                android:minHeight="0dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:backgroundTint="@color/dark_surface2" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOutputDir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Download/Bank2Mp3_output"
            android:textSize="11sp"
            android:textColor="@color/dark_text2"
            android:ellipsize="middle"
            android:maxLines="2"
            android:layout_marginBottom="14dp" />

        <!-- ═══════════ 终端转换 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶ 终端桥接"
            android:textSize="13sp"
            android:textColor="@color/dark_text"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnTerminalConvert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ 单文件 → WAV"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/dark_green"
            android:enabled="false"
            android:minHeight="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btnTerminalBatch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="批量 → WAV"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2980B9"
                android:enabled="false"
                android:minHeight="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnTerminalBatchMp3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="批量 → MP3"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/dark_green"
                android:enabled="false"
                android:minHeight="0dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnTerminalClassify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📂 批量分类 → 中文目录"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/dark_gold"
            android:enabled="false"
            android:minHeight="0dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="14dp" />

        <!-- ═══════════ WAV 格式转换 ═══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬆ WAV 转格式"
            android:textSize="13sp"
            android:textColor="@color/dark_text"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/btnWavToMp3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MP3\n192k"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@color/dark_accent"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/btnWavToMp3HQ"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MP3\n320k"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@color/dark_accent2"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/btnWavToAac"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AAC\nM4A"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@color/dark_red"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/btnWavToFlac"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FLAC"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#1ABC9C"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/btnWavToOgg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OGG"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#F39C12"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/btnWavToOpus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OPUS"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#D35400"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />
        </LinearLayout>

        <!-- ═══════════ 进度条 ═══════════ -->
        <LinearLayout
            android:id="@+id/progressContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="10dp">

            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="100" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="13sp"
                android:textColor="@color/dark_gold"
                android:minWidth="40dp"
                android:gravity="end"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- ═══════════ 日志 ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📋 日志"
                android:textSize="13sp"
                android:textColor="@color/dark_text2"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCopyLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="复制"
                android:textSize="11sp"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="@color/dark_accent" />

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清空"
                android:textSize="11sp"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:backgroundTint="@color/dark_surface2" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="等待操作..."
            android:textSize="11sp"
            android:textColor="@color/dark_text2"
            android:fontFamily="monospace"
            android:background="@color/dark_surface"
            android:padding="10dp"
            android:minHeight="200dp"
            android:gravity="top|start" />

    </LinearLayout>
</ScrollView>